# Override this file with .env.local for changes for your environment
# Supported values:
# VITE_AUTH = [enabled|disabled|proxy]
# VITE_BASE_PATH = <path>
#
# NOTE: this enables auth by default for local `npm run dev`/`npm run build`.
# The container images intentionally default the other way (the Dockerfiles set
# PHENIX_WEB_AUTH=disabled); override with .env.local if you need a different
# local default.

VITE_AUTH=enabled